# INNERVERSE 2.0 — 환경변수 예시. 복사해서 .env 로 쓰고 실제 값 채울 것.
#   cp .env.example .env        (프론트)
#   cp .env.example backend/.env (백엔드)
# ⚠️ .env 는 절대 커밋 금지 (.gitignore 에 등록됨).

# ── Frontend (Vite, VITE_ 접두사만 브라우저로 노출됨) ──
VITE_API_URL=http://localhost:8000          # FastAPI 주소
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Backend (FastAPI) ──
# AI 공급자: 아래 둘 중 "하나만" 채우면 됨. Gemini 가 있으면 Gemini 우선.
GEMINI_API_KEY=                              # Google AI Studio 키 (https://aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash                # 선택. 예: gemini-2.5-flash, gemini-2.5-flash-lite
OPENAI_API_KEY=                              # 또는 OpenAI 키 (sk-...) — Gemini 안 쓸 때만
OPENAI_MODEL=gpt-4o-mini                     # 선택
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # 서버 전용 (절대 프론트 노출 금지)
ALLOWED_ORIGINS=http://localhost:8080        # CORS 허용 도메인 (콤마 구분). 배포 시 실제 도메인으로.
